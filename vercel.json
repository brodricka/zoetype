{
  "version": 2,
  "functions": {
    "api/match.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/match",
      "dest": "/api/match.js"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/quiz",
      "dest": "/quiz.html"
    },
    {
      "src": "/result",
      "dest": "/result.html"
    },
    {
      "src": "/(.*\\.(js|json|css))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}