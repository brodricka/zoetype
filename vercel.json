{
  "version": 2,
  "outputDirectory": ".",
  "functions": {
    "api/match.js": { "maxDuration": 300 },
    "api/webhook.js": { "maxDuration": 300 },
    "api/checkout.js": { "maxDuration": 60 },
    "api/checkout-email.js": { "maxDuration": 60 }
  },
  "routes": [
    { "src": "/api/match", "dest": "/api/match.js" },
    { "src": "/api/checkout", "dest": "/api/checkout.js" },
    { "src": "/api/webhook", "dest": "/api/webhook.js" },
    { "src": "/api/checkout-email", "dest": "/api/checkout-email.js" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/quiz", "dest": "/quiz.html" },
    { "src": "/result", "dest": "/result.html" },
    { "src": "/success", "dest": "/success.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}